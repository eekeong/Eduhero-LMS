rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core authentication checks
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role 
        : 'guest';
    }
    
    function getUserId() {
      return isAuthenticated() && exists(/databases/$(database)/documents/roles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.userId 
        : null;
    }

    // ── ROLES ──────────────────────────────────────────────
    match /roles/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || getUserRole() == 'admin');
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update, delete: if isAuthenticated() && getUserRole() == 'admin';
    }

    // ── USERS ──────────────────────────────────────────────
    match /users/{userId} {
      // Allow empty check and migration lookup without auth
      allow list: if request.query.limit <= 1 || (isAuthenticated() && request.auth.token.email == resource.data.email);

      allow read: if isAuthenticated() && (
        getUserId() == userId || 
        getUserRole() == 'admin' || 
        getUserRole() == 'teacher' ||
        request.auth.token.email.lower() == resource.data.email.lower() ||
        (exists(/databases/$(database)/documents/users/$(userId)) && resource.data.uid == request.auth.uid)
      );
      
      // Update: Users can update themselves, but CANNOT change their own role.
      allow update: if isAuthenticated() && (
        getUserRole() == 'admin' || 
        (getUserId() == userId && !("role" in request.resource.data) && !("password" in request.resource.data)) ||
        // Migration bypass: Allow user to link their own account by setting UID (role must match)
        (request.resource.data.uid == request.auth.uid && request.resource.data.role == resource.data.role) ||
        // Allow session update
        (getUserId() == userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSessionId']))
      );
      
      allow create, delete: if isAuthenticated() && getUserRole() == 'admin';
    }

    // ── SETTINGS ───────────────────────────────────────────
    match /settings/{doc} {
      // Anyone can read settings (for login page branding).
      allow read: if true;
      // Only admins can change settings.
      allow write: if getUserRole() == 'admin';
    }

    // ── SUBJECTS ───────────────────────────────────────────
    match /subjects/{subjectId} {
      // Allow empty check without auth
      allow list: if request.query.limit <= 1;
      // All authenticated users can read subjects.
      allow read: if isAuthenticated();
      // Only admins manage subjects.
      allow write: if getUserRole() == 'admin';
    }

    // ── VIDEOS ─────────────────────────────────────────────
    match /videos/{videoId} {
      allow read: if isAuthenticated();
      // Admins can create/update. Teachers can only create/update their own videos.
      // Students can ONLY update the 'views' counter.
      allow create: if getUserRole() == 'admin' || (getUserRole() == 'teacher' && request.resource.data.teacherId == getUserId());
      allow update: if getUserRole() == 'admin' || 
                       (getUserRole() == 'teacher' && request.resource.data.teacherId == getUserId()) ||
                       (getUserRole() == 'student' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']));
      // Admins can delete. Teachers can delete their own videos.
      allow delete: if getUserRole() == 'admin' || (getUserRole() == 'teacher' && resource.data.teacherId == getUserId());
    }

    // ── PROGRESS ───────────────────────────────────────────
    match /progress/{progressId} {
      // Admins and Teachers can read all progress. Students can read their own.
      allow read: if getUserRole() == 'admin' || getUserRole() == 'teacher' || (getUserRole() == 'student' && resource.data.studentId == getUserId());
      // Students can update their own progress.
      allow create, update: if getUserRole() == 'student' && request.resource.data.studentId == getUserId();
      allow delete: if getUserRole() == 'admin';
    }

    // ── COMMENTS ───────────────────────────────────────────
    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == getUserId();
      allow update, delete: if getUserRole() == 'admin' || resource.data.userId == getUserId();
    }

    // ── ACTIVITY LOG ───────────────────────────────────────
    match /activityLog/{logId} {
      // Only admins can read the activity log.
      allow read: if getUserRole() == 'admin';
      // Any authenticated user can create a log entry (since frontend logs actions).
      allow create: if isAuthenticated();
      // Only admins can clear the log (delete).
      allow update, delete: if getUserRole() == 'admin';
    }
    // ── SECRETS ───────────────────────────────────────────
    match /secrets/{doc} {
      allow read: if getUserRole() == 'admin' || getUserRole() == 'teacher';
      allow write: if getUserRole() == 'admin';
    }
  }
}
